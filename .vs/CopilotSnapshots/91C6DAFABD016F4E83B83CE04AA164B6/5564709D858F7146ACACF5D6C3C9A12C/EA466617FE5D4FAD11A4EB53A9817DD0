using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Linq;
using System.Reflection;
using System.Text;
using Word=Microsoft.Office.Interop.Word;
using System.Windows.Forms;
using Microsoft.Office.Tools.Ribbon;
using iTextSharp.text;
using iTextSharp.text.pdf;

namespace PDFWordAddIn
{
    public partial class Ribbon1
    {
        public Word.Application app;
        private void Ribbon1_Load(object sender, RibbonUIEventArgs e)
        {
            app = Globals.ThisAddIn.Application;
        }

        /// <summary>
        /// 转换为PDF,与Word文件在同一目录下。该PDF为双层PDF，可用于打印，但是不可编辑
        /// </summary>
        /// <param name="sender"></param>
        /// <param name="e"></param>

        private const string GhostscriptResourceName = "PDFWordAddIn.gswin64c.exe";
        private static readonly string TempDir = Path.Combine(Path.GetTempPath(), "BidPdfGenerator");
        private static readonly string TempGhostscriptExe = Path.Combine(TempDir, "gswin64c.exe");


        private void btnConvertToPDF_Click(object sender, RibbonControlEventArgs e)
        {
            
            string path = app.ActiveDocument.FullName;
            try
            {
                // 1. 初始化临时目录, 优先查找本机已安装的 Ghostscript，找不到再解压嵌入的 Ghostscript
                Directory.CreateDirectory(TempDir);
                string gsExe = GetGhostscriptExePath();

                // 2. 生成带文本层的 PDF
                string textPdfPath = Path.Combine(TempDir, "text_layer.pdf");
                ConvertWordToPDF(textPdfPath);

                // 3. 分页渲染图片（生成 page-1.png, page-2.png 等）
                string imagePattern = Path.Combine(TempDir, "page-%d.png"); // 关键：%d 表示页码
                RunGhostscript(textPdfPath, imagePattern, dpi: 300, ghostscriptExePath: gsExe);

                // 4. 创建新PDF：图片在上层，文本在下层
                string outputPath = Path.Combine(
                    Path.GetDirectoryName(app.ActiveDocument.FullName),
                    Path.GetFileNameWithoutExtension(app.ActiveDocument.Name) + "_Bid.pdf");

                CreatePdfWithImageOverlay(textPdfPath, Path.Combine(TempDir, "page-{0}.png"), outputPath, false);

                MessageBox.Show("转换成功！");
            }
            catch (Exception ex)
            {
                MessageBox.Show("转换失败：" + ex.Message);
            }
            finally
            {
                // 清理临时文件
                if (Directory.Exists(TempDir))
                    Directory.Delete(TempDir, recursive: true);
            }
        }

        // 1. 解压 Ghostscript
        private void ExtractGhostscript()
        {
            using (Stream stream = Assembly.GetExecutingAssembly().GetManifestResourceStream(GhostscriptResourceName))
            using (FileStream fs = new FileStream(GhostscriptExePath, FileMode.Create))
            {
                stream.CopyTo(fs);
            }
        }

        //2. 用 Word 生成带文本层的 PDF
        private void ConvertWordToPDF(string pdfFilePath)
        {
            Word.Document doc = app.ActiveDocument;

            try
            {
                doc.SaveAs2(
                    FileName: Path.GetFullPath(pdfFilePath),
                    FileFormat: Word.WdSaveFormat.wdFormatPDF,
                    AddToRecentFiles: false,
                    EmbedTrueTypeFonts: true,  // 嵌入字体（防止乱码）
                    SaveFormsData: false,
                    SaveAsAOCELetter: false,
                    Encoding: Microsoft.Office.Core.MsoEncoding.msoEncodingUTF8
                ); ;
            }
            catch (Exception ex)
            {
                MessageBox.Show(ex.Message);
            }
        }

        // 3. 调用Ghostscript渲染PDF为图片（覆盖层）
        private void RunGhostscript(string inputPdf, string outputPattern, int dpi)
        {
            // 输出文件名模式包含页码占位符 %d
            string args = $"-dSAFER -dBATCH -dNOPAUSE -sDEVICE=pngalpha -r{dpi} " +
                          $"-sOutputFile=\"{outputPattern}\" \"{inputPdf}\"";

            ProcessStartInfo psi = new ProcessStartInfo
            {
                FileName = GhostscriptExePath,
                Arguments = args,
                UseShellExecute = false,
                CreateNoWindow = true
            };

            using (Process process = Process.Start(psi))
            {
                process.WaitForExit();
                if (process.ExitCode != 0)
                    throw new Exception("Ghostscript渲染失败");
            }
        }

        // 4. 创建新PDF：图片在上层，文本在下层
        private void CreatePdfWithImageOverlay(string textPdfPath, string imagePattern, string outputPath, bool isBackGround = false)
        {
            PdfReader reader = null;
            FileStream fs = null;
            PdfStamper stamper = null;

            try
            {
                reader = new PdfReader(textPdfPath);
                fs = new FileStream(outputPath, FileMode.Create);
                stamper = new PdfStamper(reader, fs);

                // 遍历每一页
                for (int pageNum = 1; pageNum <= reader.NumberOfPages; pageNum++)
                {
                    // 加载对应页码的图片（例如 page-1.png, page-2.png）
                    string imagePath = string.Format(imagePattern, pageNum);
                    if (!File.Exists(imagePath))
                        throw new FileNotFoundException($"页码 {pageNum} 的图片未找到: {imagePath}");

                    Image image = Image.GetInstance(imagePath);
                    image.SetAbsolutePosition(0, 0);
                    image.ScaleAbsolute(reader.GetPageSize(pageNum).Width, reader.GetPageSize(pageNum).Height);

                    // 将图片覆盖到当前页
                    if (isBackGround)
                    {
                        PdfContentByte canvas = stamper.GetUnderContent(pageNum);
                        canvas.AddImage(image);
                    }
                    else
                    {
                        PdfContentByte canvas = stamper.GetOverContent(pageNum);
                        canvas.AddImage(image);
                    }
                }
            }
            finally
            {
                stamper?.Close();
                reader?.Close();
                fs?.Close();
            }
        }
    
    }
}
